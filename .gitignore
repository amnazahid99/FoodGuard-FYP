*.tar.gz
*.zip

# ===========================================
# Claude Code (AI Assistant)
# ===========================================
.claude/

# ===========================================
# Project root files (not needed in git)
# ===========================================

# Build/Package managers (root-level only — leading slash anchors to repo root
# so we don't accidentally ignore FoodGuard-AI/app/main.py, etc.)
/uv.lock
/pyproject.toml
/main.py


# CLAUDE.md (project instructions for AI assistants)
CLAUDE.md

# FoodGuard Viva Knowledge Base - not committed to GitHub
foodguard-viva-knowledge-base.txt