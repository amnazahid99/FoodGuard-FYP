*.pem
*.key
*.crt

# Docker
.dockerignore

# Secrets (explicitly keep .env files in git if needed, otherwise remove)
# .env

# ===========================================
# Project-specific ignores
# ===========================================

# FoodGuard-AI
FoodGuard-AI/venv/
FoodGuard-AI/__pycache__/
FoodGuard-AI/.pytest_cache/

# FoodGuard-Backend
