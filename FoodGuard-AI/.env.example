# Fireworks AI API Key (get from https://fireworks.ai/account/api-keys)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Groq API Key (get from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio - Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Spoonacular API Key (https://spoonacular.com/food-api) - recipe search/details
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# CalorieNinjas API Key (https://calorieninjas.com/api) - nutrition lookups
CALORIENINJAS_API_KEY=your_calorieninjas_api_key_here

# Service Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Cache Configuration (optional - uses in-memory cache if not set)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600
