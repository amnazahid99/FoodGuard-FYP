NODE_ENV=development
# 5001 (not 5000 — macOS AirPlay Receiver squats on :5000)
PORT=5001

# Comma-separated allowed origins (Vite dev server runs on :3000)
CLIENT_URL=http://localhost:3000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/foodguard

# JWT secrets (use long random strings in production)
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# FastAPI AI microservice base URL
FASTAPI_URL=http://localhost:8000

# ── Stripe (test mode) — SERVER-ONLY secret, never expose to the frontend ──
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_CURRENCY=pkr
STRIPE_WEBHOOK_SECRET=

# Google OAuth (for Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret